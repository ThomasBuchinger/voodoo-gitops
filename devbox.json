{
  "packages": [
    "renovate@43.150.1",
    "fluxcd@2.8.8",
    "opencode@0.15.29"
  ],
  "env": {
    "OPENCODE_CONFIG": ".agents/opencode.json",
    "KUBECONFIG": "./kubeconfig"
  },
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null"
    ],
    "scripts": {
      "update": [
        "flux reconcile source git voodoo-gitops"
      ]
    }
  }
}
